# 复制为 .env.local 后填写（.env.local 已被 .gitignore 忽略）
#
# ⚠️ 浏览器不能直连 LLM（CORS + key 暴露）。本工程用代理：
#   - dev：vite.config.ts 把 /api/llm/* 转发到 LLM_BASE_URL，并在服务端注入 LLM_API_KEY（不进浏览器）；
#   - prod：用真实后端接管 /api/llm，key 放后端。
#
# 所以 key/baseURL 用【不带 VITE_ 前缀】的服务端变量；只有模型名（非敏感）用 VITE_ 前缀给客户端。

# ---- 服务端变量（不进浏览器 bundle）----
# OpenAI 兼容的 baseURL（通常含 /v1）
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# API Key（仅代理/后端使用，不暴露给浏览器）
LLM_API_KEY=

# ---- 客户端变量（会进浏览器，必须带 VITE_ 前缀，否则浏览器读不到）----
# 模型名（非敏感）
VITE_LLM_MODEL=glm-5.1

# ---- 腾讯云混元3D（ai3d）CAM 密钥（服务端变量，不带 VITE_ 前缀，不进浏览器 bundle）----
# 仅 vite dev middleware（build/hunyuanMiddleware.ts）使用，注入到 Python 子进程调腾讯云 SDK。
# 获取：https://console.cloud.tencent.com/cam/capi（需先开通 https://console.cloud.tencent.com/ai3d）
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
